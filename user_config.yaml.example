# ============================================
# APT Emulation Platform - User Configuration
# ============================================
# 
# INSTRUCTIONS:
# 1. Copy this file to: user_config.yaml
# 2. Replace all values marked with YOUR_ with your actual details
# 3. Run: python3 main.py --config user_config.yaml
# ============================================

company:
  name: "YOUR_COMPANY_NAME"
  environment: "production"

network:
  domain: "YOUR_COMPANY_DOMAIN"

email:
  enabled: true
  server: "smtp.YOUR_DOMAIN"
  test_recipient: "security-test@YOUR_DOMAIN"

edr:
  enabled: true
  vendor: "YOUR_EDR_VENDOR"

siem:
  enabled: true
  url: "https://splunk.YOUR_DOMAIN"

test_scripts:
  path: "/opt/security/tests/"

ransomware:
  test_file_path: "/tmp/ransomware_test.txt"

advanced:
  safe_mode: true
  log_level: "INFO"
